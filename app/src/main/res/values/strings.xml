    <string name="adb_setup_title">Cloud Photo Picker Setup</string>
    <string name="adb_setup_description">Make your Immich photos available in the system photo picker used by other apps. Requires a one-time ADB setup.</string>
    <string name="adb_enable_label">Enable:</string>
    <string name="adb_enable_command">adb shell device_config override mediaprovider allowed_cloud_providers codes.dreaming.cloudmedia</string>
    <string name="adb_disable_label">Disable:</string>
    <string name="adb_disable_command">adb shell device_config clear_override mediaprovider allowed_cloud_providers</string>
    <string name="adb_setup_footer">Connect your device to a computer with ADB installed and run the command above. This persists across reboots and app updates.</string>
